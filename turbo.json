{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": ["RENDER_*", "DATABASE_URL", "PORT"],
  "tasks": {
    "prisma:generate": {},
    "build": {
      "dependsOn": ["^build", "^prisma:generate"],
      "outputs": [".next/**", "!.next/cache/**", "apps/api/dist/**"]
    },
    "dev": {
      "dependsOn": ["^prisma:generate"],
      "persistent": true,
      "cache": false
    },
    "lint": {},
    "ci:lint": {},
    "test": {},
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DATABASE_URL", "E2E_TESTING", "CI"]
    }
  }
}
